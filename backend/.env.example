# DEI VERBUM - Configuração do Backend

# Ambiente
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL="postgresql://dei_verbum:deiverbum123@localhost:5432/dei_verbum_prod"

# JWT
JWT_SECRET="sua-chave-super-secreta-minimo-32-caracteres"
JWT_EXPIRES_IN="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# URLs
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Stripe (Cartões)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Asaas (PIX e Boleto)
ASAAS_API_KEY="$aact_..."
ASAAS_ENV=sandbox

# Storage (imagens)
STORAGE_PROVIDER=local
# STORAGE_ACCESS_KEY=...
# STORAGE_SECRET_KEY=...
# STORAGE_BUCKET=dei-verbum
# STORAGE_ENDPOINT=...
# STORAGE_REGION=

# Configurações da Loja
STORE_NAME="DEI VERBUM"
STORE_EMAIL="contato@deiverbum.com.br"
STORE_PHONE=""
