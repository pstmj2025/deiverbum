{
  "name": "dei-verbum-api",
  "version": "1.0.0",
  "description": "API do sistema DEI VERBUM - E-commerce de livros e papelaria",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts --fix",
    "test": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "ecommerce",
    "books",
    "livros",
    "api"
  ],
  "author": "Rodrigo - DEI VERBUM",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^5.0.5",
    "redis": "^4.7.0",
    "slugify": "^1.6.6",
    "stripe": "^17.6.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.1",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.20.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
